<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header: small-caps label + speed pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NOW PLAYING"
            android:textColor="#38BDF8"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0×"
            android:textColor="#F5F5FA"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/widget_speed_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>
    </LinearLayout>

    <!-- Novel title -->
    <TextView
        android:id="@+id/widget_novel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Chapter title -->
    <TextView
        android:id="@+id/widget_chapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Tap to open Audiobook"
        android:textColor="#F5F5FA"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_widget_prev"
            android:contentDescription="Previous paragraph"/>

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:padding="15dp"
            android:src="@drawable/ic_widget_play"
            android:background="@drawable/widget_play_bg"
            android:contentDescription="Play or pause"/>

        <ImageView
            android:id="@+id/widget_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_widget_next"
            android:contentDescription="Next paragraph"/>
    </LinearLayout>

    <!-- Scrollable paragraph -->
    <ListView
        android:id="@+id/widget_paragraph_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="10dp"
        android:dividerHeight="0dp"
        android:divider="@android:color/transparent"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="12dp"/>
</LinearLayout>
